{
  "name": "von-cms",
  "private": true,
  "version": "1.25.8",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint:php": "node server/lint-php.cjs",
    "prebuild": "node -e \"const fs=require('fs'); ['dist', 'public/assets'].forEach(d => { if(fs.existsSync(d)) fs.rmSync(d, {recursive:true, force:true}); });\"",
    "build": "vite build",
    "postbuild": "node -e \"const fs=require('fs-extra'); fs.copySync('public', 'dist', {overwrite: true, filter: (src) => !src.includes('assets') && !src.includes('index.html') && !src.includes('migrations') && !src.includes('install.sql')}); if(fs.existsSync('docs')) fs.copySync('docs', 'dist/docs'); if(fs.existsSync('dist/von_config.php')) fs.renameSync('dist/von_config.php', 'dist/von_config.sample.php');\" && node server/copy-theme-manifests.cjs",
    "start:api": "node server/themes-api.cjs",
    "test:integration": "node server/test-integration.cjs",
    "ci:gate": "npm run typecheck && npm run build && npm run test:smoke",
    "preview": "vite preview",
    "test": "npm run test:smoke",
    "test:smoke": "node server/test-integration.cjs"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.13.56",
    "@tiptap/core": "^3.27.4",
    "@tiptap/extension-image": "^3.27.4",
    "@tiptap/extension-link": "^3.27.4",
    "@tiptap/extension-table": "^3.27.4",
    "@tiptap/extension-text-align": "^3.27.4",
    "@tiptap/extension-text-style": "^3.27.4",
    "@tiptap/pm": "^3.27.4",
    "@tiptap/react": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "@types/nprogress": "^0.2.3",
    "adm-zip": "^0.6.0",
    "cors": "^2.8.6",
    "dompurify": "^3.4.12",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "fs-extra": "^11.3.6",
    "lucide-react": "^1.24.0",
    "multer": "^2.2.0",
    "nprogress": "^0.2.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-gravatar": "^2.6.3",
    "react-hot-toast": "^2.6.0",
    "react-is": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "react-share": "^5.2.2",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@prettier/plugin-php": "^0.25.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-gravatar": "^2.6.14",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.3",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  },
  "overrides": {
    "rimraf": "^6.0.0"
  }
}
